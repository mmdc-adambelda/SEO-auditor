{
  "name": "seo-auditor",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @seo-auditor/database generate",
    "db:migrate": "pnpm --filter @seo-auditor/database migrate:dev",
    "db:push": "pnpm --filter @seo-auditor/database db:push",
    "db:studio": "pnpm --filter @seo-auditor/database studio",
    "db:seed": "pnpm --filter @seo-auditor/database seed"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0"
  }
}
