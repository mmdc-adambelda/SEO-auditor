# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/seo_auditor?schema=public"

# ─── Redis (BullMQ) ───────────────────────────────────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# ─── API Server ───────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT="4000"
API_SECRET="change-this-to-a-secure-random-string-at-least-32-chars"
CORS_ORIGIN="http://localhost:3000"

# ─── Google APIs ──────────────────────────────────────────────────────────────
GOOGLE_PAGESPEED_API_KEY="your-google-pagespeed-api-key"
GOOGLE_SEARCH_CONSOLE_CLIENT_ID="your-gsc-client-id"
GOOGLE_SEARCH_CONSOLE_CLIENT_SECRET="your-gsc-client-secret"
GOOGLE_ANALYTICS_CLIENT_ID="your-ga-client-id"
GOOGLE_ANALYTICS_CLIENT_SECRET="your-ga-client-secret"

# ─── DataForSEO ───────────────────────────────────────────────────────────────
DATAFORSEO_LOGIN="your-dataforseo-login"
DATAFORSEO_PASSWORD="your-dataforseo-password"

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-your-openai-api-key"
OPENAI_MODEL="gpt-4o"

# ─── Storage (for report exports) ─────────────────────────────────────────────
STORAGE_PATH="./storage"
# Optional: S3 for production
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_S3_REGION="us-east-1"

# ─── Web App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXTAUTH_SECRET="change-this-to-a-secure-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ─── Crawler Settings ─────────────────────────────────────────────────────────
CRAWLER_MAX_PAGES="500"
CRAWLER_MAX_DEPTH="5"
CRAWLER_CONCURRENCY="10"
CRAWLER_REQUEST_TIMEOUT="30000"
CRAWLER_USER_AGENT="SEOAuditor/1.0 (+https://seoauditor.io/bot)"
